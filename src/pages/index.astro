---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero -->
  <section class="min-h-[90vh] flex flex-col justify-center max-w-5xl mx-auto px-6 py-20">
    <p class="font-mono text-[#00ff88] text-sm mb-4 tracking-widest uppercase">
      $ whoami
    </p>
    <h1 class="text-5xl md:text-7xl font-bold text-[#e6edf3] leading-tight mb-4">
      Sandeep R N
    </h1>
    <div class="flex flex-wrap items-center gap-2 mb-6">
      <span class="text-xl md:text-3xl text-[#8b949e] font-mono">Senior Cloud Engineer</span>
      <span class="text-xl md:text-3xl text-[#00ff88] font-mono">→</span>
      <span class="text-xl md:text-3xl text-[#e6edf3] font-mono">Platform Engineer</span>
      <span class="cursor-blink"></span>
    </div>
    <p class="text-[#8b949e] text-lg max-w-2xl mb-10 leading-relaxed">
      Automation-first. Observability-driven. Multi-cloud.<br />
      3+ years in SRE — building infra that scales, pipelines that ship, and dashboards that tell the truth.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="#projects"
        class="px-6 py-3 bg-[#00ff88] text-[#0d1117] font-semibold rounded font-mono text-sm hover:bg-[#00cc6a] transition-colors"
      >
        ./view-projects
      </a>
      <a
        href="/Sandeep_RN_Resume.pdf"
        target="_blank"
        class="px-6 py-3 border border-[#00ff88] text-[#00ff88] rounded font-mono text-sm hover:bg-[#00ff8815] transition-colors"
      >
        ./resume.pdf
      </a>
      <a
        href="#contact"
        class="px-6 py-3 border border-[#30363d] text-[#e6edf3] rounded font-mono text-sm hover:border-[#00ff88] hover:text-[#00ff88] transition-colors"
      >
        ./contact
      </a>
    </div>

    <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-6">
      {[
        { value: '3+', label: 'Years in SRE' },
        { value: '1000+', label: 'Servers managed' },
        { value: 'AWS · Azure · OCI', label: 'Multi-cloud' },
        { value: 'CKA · TF Assoc', label: 'In Progress' },
      ].map((stat) => (
        <div class="border border-[#30363d] rounded-lg p-4 bg-[#161b22]">
          <div class="font-mono text-[#00ff88] font-bold text-xl mb-1">{stat.value}</div>
          <div class="text-[#8b949e] text-xs uppercase tracking-wide">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- About -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-[#30363d]">
    <p class="font-mono text-[#00ff88] text-sm mb-2 tracking-widest uppercase">$ cat about.md</p>
    <h2 class="text-3xl font-bold mb-8">About</h2>
    <div class="grid md:grid-cols-3 gap-10">
      <div class="md:col-span-2 space-y-4 text-[#8b949e] leading-relaxed">
        <p>
          I'm a Cloud &amp; SRE Engineer at SymphonyAI, Bengaluru — managing production reliability across a
          <span class="text-[#e6edf3]">1000+ server estate on Azure and OCI</span>. My day-to-day spans
          large-scale observability (15k+ URL checks), Kubernetes platform adoption, blameless RCAs,
          and eliminating operational toil through Python and API automation.
        </p>
        <p>
          I've executed a zero-gap <span class="text-[#e6edf3]">Zabbix 4 → 7 migration</span> at scale,
          built idempotent Ansible playbooks that cut server onboarding from 30 min to under 2 min, and
          implemented OCI DR Protection Groups that measurably improved RTO/RPO for Tier-1 customers.
        </p>
        <p>
          Now deepening my platform engineering skills — currently pursuing <span class="text-[#00ff88]">CKA</span> and
          <span class="text-[#00ff88]">Terraform Associate</span>, and building real IaC and containerisation
          projects to close the gap from SRE to Platform Engineering.
        </p>
      </div>
      <div class="space-y-3">
        <div class="border border-[#30363d] rounded-lg p-4 bg-[#161b22]">
          <div class="text-[#00ff88] font-mono text-xs uppercase tracking-widest mb-2">Currently</div>
          <div class="text-[#e6edf3] text-sm">Senior Cloud Engineer @ SymphonyAI</div>
          <div class="text-[#8b949e] text-xs mt-1">Apr 2026 – Present</div>
        </div>
        <div class="border border-[#30363d] rounded-lg p-4 bg-[#161b22]">
          <div class="text-[#00ff88] font-mono text-xs uppercase tracking-widest mb-2">Studying</div>
          <div class="text-[#e6edf3] text-sm">CKA — 15% <span class="text-[#8b949e]">→ Aug 2026</span></div>
          <div class="text-[#e6edf3] text-sm mt-1">Terraform Associate — 28% <span class="text-[#8b949e]">→ Oct 2026</span></div>
        </div>
        <div class="border border-[#30363d] rounded-lg p-4 bg-[#161b22]">
          <div class="text-[#00ff88] font-mono text-xs uppercase tracking-widest mb-2">Based in</div>
          <div class="text-[#e6edf3] text-sm">Bengaluru, India</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-[#30363d]">
    <p class="font-mono text-[#00ff88] text-sm mb-2 tracking-widest uppercase">$ ls ./skills</p>
    <h2 class="text-3xl font-bold mb-10">Technical Stack</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {[
        { category: 'Cloud', items: ['AWS (EC2, S3, IAM, CloudWatch)', 'Azure (AZ-104, AZ-400)', 'OCI (Compute, Networking, DR)'] },
        { category: 'IaC & Automation', items: ['Terraform', 'Ansible', 'Azure Bicep', 'Python (API automation)', 'Bash'] },
        { category: 'Containers & Orchestration', items: ['Kubernetes', 'Docker', 'Amazon ECR', 'Amazon EKS'] },
        { category: 'Observability', items: ['Prometheus', 'Grafana', 'Zabbix (v4→v7)', 'Azure Monitor', 'Centreon', 'JMX / Tomcat APM'] },
        { category: 'CI/CD', items: ['Azure DevOps Pipelines', 'Git', 'YAML-based release automation'] },
        { category: 'Incident Management', items: ['PagerDuty', 'Jira', 'RCA authoring', 'Production bridge facilitation'] },
      ].map((group) => (
        <div class="border border-[#30363d] rounded-lg p-5 bg-[#161b22]">
          <h3 class="font-mono text-[#00ff88] text-xs uppercase tracking-widest mb-3">{group.category}</h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="px-3 py-1 bg-[#0d1117] border border-[#30363d] rounded text-[#e6edf3] text-sm font-mono">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="max-w-5xl mx-auto px-6 py-16 border-t border-[#30363d]">
    <p class="font-mono text-[#00ff88] text-sm mb-2 tracking-widest uppercase">$ cat ./projects</p>
    <h2 class="text-3xl font-bold mb-3">Featured Projects</h2>
    <p class="text-[#8b949e] mb-10">Real infra. Real pipelines. Real observability.</p>
    <div class="grid md:grid-cols-2 gap-6">
      {[
        {
          title: 'Docker Multi-Service App → ECR',
          tags: ['Docker', 'AWS ECR', 'Containerization'],
          desc: 'Multi-service application containerized with Docker and pushed to Amazon ECR with proper image tagging and lifecycle policies.',
          slug: 'docker-ecr',
          done: true,
        },
        {
          title: 'Monitoring Stack: Prometheus + Grafana + Zabbix',
          tags: ['Prometheus', 'Grafana', 'Zabbix', 'Observability'],
          desc: 'Production-grade monitoring stack with alerting rules, custom dashboards, and Zabbix integration for infrastructure visibility.',
          slug: 'monitoring-stack',
          done: true,
        },
        {
          title: 'Career Tracker App',
          tags: ['FastAPI', 'React', 'OCI', 'Full-Stack'],
          desc: 'Full-stack career tracking application. FastAPI backend on Oracle Cloud Free Tier, React frontend at sandeeprn.in/tracker.',
          slug: 'career-tracker',
          done: false,
        },
        {
          title: 'EKS Cluster via Terraform',
          tags: ['Terraform', 'EKS', 'AWS', 'IaC'],
          desc: 'Production-style EKS cluster provisioned using Terraform VPC and EKS modules with remote state in S3 + DynamoDB locking.',
          slug: 'eks-terraform',
          done: false,
        },
      ].map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="group border border-[#30363d] rounded-lg p-6 bg-[#161b22] hover:border-[#00ff88] transition-colors block"
        >
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-semibold text-[#e6edf3] group-hover:text-[#00ff88] transition-colors leading-tight">
              {project.title}
            </h3>
            {!project.done && (
              <span class="ml-3 shrink-0 px-2 py-0.5 text-xs font-mono bg-[#00ff8820] text-[#00ff88] border border-[#00ff8840] rounded">
                in progress
              </span>
            )}
          </div>
          <p class="text-[#8b949e] text-sm mb-4 leading-relaxed">{project.desc}</p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="px-2 py-0.5 text-xs font-mono text-[#8b949e] border border-[#30363d] rounded">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="max-w-5xl mx-auto px-6 py-16 border-t border-[#30363d]">
    <p class="font-mono text-[#00ff88] text-sm mb-2 tracking-widest uppercase">$ ./contact.sh</p>
    <h2 class="text-3xl font-bold mb-4">Let's Connect</h2>
    <p class="text-[#8b949e] mb-8 max-w-lg">
      Open to Platform Engineering and DevOps roles. Bengaluru-based.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="mailto:sandeeprn1998@gmail.com"
        class="flex items-center gap-2 px-5 py-3 border border-[#30363d] rounded font-mono text-sm text-[#e6edf3] hover:border-[#00ff88] hover:text-[#00ff88] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z"/></svg>
        sandeeprn1998@gmail.com
      </a>
      <a
        href="https://github.com/Sandeep-RN"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 px-5 py-3 border border-[#30363d] rounded font-mono text-sm text-[#e6edf3] hover:border-[#00ff88] hover:text-[#00ff88] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/></svg>
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/sandeep-rn/"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 px-5 py-3 border border-[#30363d] rounded font-mono text-sm text-[#e6edf3] hover:border-[#00ff88] hover:text-[#00ff88] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/></svg>
        LinkedIn
      </a>
    </div>
  </section>
</Layout>
