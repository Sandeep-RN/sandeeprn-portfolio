---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={`${project.data.title} — Sandeep R N`} description={project.data.description}>
  <div class="max-w-3xl mx-auto px-6 py-16">
    <!-- Breadcrumb -->
    <div class="font-mono text-sm text-[#8b949e] mb-8">
      <a href="/" class="hover:text-[#00ff88] transition-colors">~</a>
      <span class="mx-2">/</span>
      <a href="/projects" class="hover:text-[#00ff88] transition-colors">projects</a>
      <span class="mx-2">/</span>
      <span class="text-[#e6edf3]">{project.id}</span>
    </div>

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        {project.data.status === 'in-progress' && (
          <span class="px-2 py-0.5 text-xs font-mono bg-[#00ff8820] text-[#00ff88] border border-[#00ff8840] rounded">
            in progress
          </span>
        )}
        {project.data.status === 'done' && (
          <span class="px-2 py-0.5 text-xs font-mono bg-[#30363d] text-[#8b949e] border border-[#30363d] rounded">
            complete
          </span>
        )}
      </div>
      <h1 class="text-4xl font-bold text-[#e6edf3] mb-4">{project.data.title}</h1>
      <p class="text-[#8b949e] text-lg mb-6">{project.data.description}</p>
      <div class="flex flex-wrap gap-2 mb-6">
        {project.data.tags.map((tag: string) => (
          <span class="px-3 py-1 bg-[#0d1117] border border-[#30363d] rounded text-[#e6edf3] text-sm font-mono">
            {tag}
          </span>
        ))}
      </div>
      {project.data.github && (
        <a
          href={project.data.github}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2 border border-[#30363d] rounded font-mono text-sm text-[#e6edf3] hover:border-[#00ff88] hover:text-[#00ff88] transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/></svg>
          View on GitHub
        </a>
      )}
    </div>

    <!-- MDX Content -->
    <div class="prose prose-invert prose-pre:bg-[#0d1117] prose-pre:border prose-pre:border-[#30363d] prose-code:text-[#00ff88] prose-code:bg-[#0d1117] prose-code:px-1 prose-code:rounded prose-headings:text-[#e6edf3] prose-a:text-[#00ff88] prose-th:text-[#e6edf3] prose-td:text-[#8b949e] max-w-none">
      <Content />
    </div>

    <!-- Back link -->
    <div class="mt-16 pt-8 border-t border-[#30363d]">
      <a href="/projects" class="font-mono text-sm text-[#8b949e] hover:text-[#00ff88] transition-colors">
        ← back to projects
      </a>
    </div>
  </div>
</Layout>
